# Netlify redirects — static multi-page site
# NO catch-all to index.html — each URL is a real file

# Redirect bare paths to trailing slash versions
/directory    /directory/    301
/locations    /locations/    301
/blog         /blog/         301
/about        /about/        301
/contact      /contact/      301
/privacy      /privacy/      301
/terms        /terms/        301
/cookie       /cookie/       301

# 404 fallback
/*            /404.html      404
